<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1><%= t(:"views.lms_users.index.title")%></h1>
      </div>
      <div class="col-sm-6">
        <div class="float-sm-right">
          <%= link_to t(:"views.lms_users.index.button_new"), new_lms_user_path, class: "btn btn-primary btn-sm" %>
          <%= link_to t(:"views.lms_users.index.button_import"), new_lms_user_imports_path, class: "btn btn-primary btn-sm" %>
        </div>
      </div>
    </div>
  </div>
</div>

<section class="content">
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <div class="card-title"></div>
          <%= simple_form_for @condition, url: lms_users_path, method: :get do |f| %>
            <div class="card-body">
              <%= f.error_notification %>
              <div class="form-group">
                <%= render partial: 'search_conditions', locals: {form: f} %>
              </div>
            </div>
            <div class="card-footer">
              <%= f.submit t(:"views.lms_users.index.button_search"), class: "btn btn-primary btn-sm"%>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <% unless @lms_users.nil? %>
      <div class="row">
        <div class="col-md-12">
          <div class="card">
            <div class="card-title"></div>
            <div class="card-body">
               <%= render partial: 'search_results' %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</section>
