<% unless @lti_import_history_errors.blank? %>
  <div class="card">
    <div class="card-header">
      <%= t(:"views.lti.import_histories.show.error_info_title") %>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-hover table-striped table-sm">
          <thead class="thead-dark">
          <tr>
            <th><%= t(:"views.lti.import_histories.show.table_import_histories.line_no")%></th>
            <th><%= t(:"views.lti.import_histories.show.table_import_histories.error_message")%></th>
          </tr>
          </thead>
          <tbody>
          <% @lti_import_history_errors.each do |error| %>
            <tr>
              <td><%= error.line_no %></td>
              <td><%= convert_rf(error.error_message) %></td>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>




